# =============================================================================
# Piattaforma Turistica — environment variables
# Copy this file to `.env.local` and fill in the real values.
# Never commit `.env.local` to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Public URL of the site (used for redirects, emails, Stripe return URLs).
# In production set this to https://your-domain.com (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Project URL — Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (public) key — safe to expose to the browser, governed by RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...REPLACE_ME

# Service role key — SERVER ONLY, bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...REPLACE_ME

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
# Publishable key (browser) — pk_test_... in dev, pk_live_... in prod
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Secret key (server only) — sk_test_... in dev, sk_live_... in prod
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Webhook signing secret — `stripe listen` in dev, dashboard endpoint in prod
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# -----------------------------------------------------------------------------
# Resend (transactional email)
# -----------------------------------------------------------------------------
# API key — https://resend.com/api-keys
RESEND_API_KEY=re_REPLACE_ME

# Verified sender — must be a domain you own and have verified in Resend
RESEND_FROM_EMAIL=noreply@your-domain.com

# (Optional) Resend webhook signing secret if you wire up event webhooks
RESEND_WEBHOOK_SECRET=whsec_REPLACE_ME
